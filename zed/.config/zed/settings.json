{
  // Appearance
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "theme": "VSCode Dark Modern",
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Mocha",
  },
  "ui_font_features": {
    "ligatures": true,
  },
  "ui_font_family": "Monaspace Neon NF",
  "ui_font_size": 17.0,
  "buffer_font_family": "Monaspace Neon NF",
  "buffer_font_size": 16.0,
  "buffer_line_height": "comfortable",
  "agent_ui_font_size": 17.0,
  "agent_buffer_font_size": 15.0,

  // Window and chrome
  "use_system_window_tabs": true,
  "when_closing_with_no_tabs": "keep_window_open",
  "bottom_dock_layout": "full",
  "title_bar": {
    "show_menus": true,
    "show_project_items": true,
    "show_branch_name": true,
    "show_branch_status_icon": true,
    "show_user_menu": true,
    "show_user_picture": false,
    "show_sign_in": false,
    "show_onboarding_banner": false,
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "tabs": {
    "show_diagnostics": "all",
    "file_icons": true,
    "git_status": true,
  },
  "toolbar": {
    "agent_review": false,
    "breadcrumbs": false,
    "code_actions": false,
    "selections_menu": false,
    "quick_actions": false,
  },

  // Editor behavior
  "vim_mode": true,
  "vim": {
    "use_smartcase_find": true,
    "use_system_clipboard": "never",
    "toggle_relative_line_numbers": true,
  },
  "cursor_blink": false,
  "relative_line_numbers": "enabled",
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": false,
    "runnables": true,
  },
  "indent_guides": {
    "enabled": false,
  },
  "inlay_hints": {
    "show_background": true,
    "enabled": false,
  },
  "code_lens": "menu",
  "show_whitespaces": "none",
  "scrollbar": {
    "show": "never",
  },
  "minimap": {
    "show": "never",
  },
  "seed_search_query_from_cursor": "selection",
  "extend_comment_on_newline": false,
  "close_on_file_delete": true,
  "show_signature_help_after_edits": false,
  "autosave": "on_focus_change",
  "colorize_brackets": true,
  "formatter": "prettier",
  "jsx_tag_auto_close": {
    "enabled": true,
  },
  "use_smartcase_search": true,
  "show_completions_on_input": false,

  // Search and files
  "file_finder": {
    "modal_max_width": "large",
  },
  "search": {
    "button": false,
    "case_sensitive": false,
  },

  // Formatting and diagnostics
  "format_on_save": "on",
  "code_actions_on_format": {
    "source.fixAll.eslint": true,
  },
  "prettier": {
    "allowed": true,
  },
  "diagnostics": {
    "button": true,
    "inline": {
      "enabled": true,
    },
  },

  // Panels and tools
  "project_panel": {
    "button": true,
    "dock": "left",
    "default_width": 350,
    "hide_root": true,
    "file_icons": true,
    "folder_icons": true,
    "bold_folder_labels": false,
    "git_status": true,
    "git_status_indicator": true,
    "diagnostic_badges": true,
    "indent_guides": {
      "show": "always",
    },
    "scrollbar": {
      "horizontal_scroll": false,
      "show": "never",
    },
  },
  "git_panel": {
    "button": true,
    "dock": "left",
    "default_width": 350,
    "show_count_badge": true,
    "file_icons": true,
    "tree_view": true,
  },
  "collaboration_panel": {
    "button": false,
    "dock": "right",
  },
  "outline_panel": {
    "default_width": 300,
    "button": false,
    "dock": "right",
  },
  "debugger": {
    "button": false,
    "dock": "right",
  },
  "terminal": {
    "button": false,
    "font_size": 17.0,
    "dock": "bottom",
  },

  // Agent
  "edit_predictions": {
    "provider": "zed",
    "disabled_globs": [],
  },
  "show_edit_predictions": true,
  "agent": {
    "button": false,
    "dock": "right",
    "sidebar_side": "right",
    "flexible": false,
    "favorite_models": [],
    "model_parameters": [],
    "show_turn_stats": true,
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5.1-codex-mini",
    },
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },

  // Session and privacy
  "session": {
    "trust_all_worktrees": true,
  },
  "redact_private_values": false,

