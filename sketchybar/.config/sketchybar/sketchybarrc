PLUGIN_DIR="$CONFIG_DIR/plugins"

##### Hyperland Style Bar #####
# Single floating bar with workspaces and status in visual groups

# Floating bar - Ghostty style with pill-style items
sketchybar --bar position=top \
    height=34 \
    blur_radius=15 \
    color=0x00000000 \
    sticky=off \
    margin=0 \
    padding_left=8 \
    padding_right=8 \
    corner_radius=12 \
    y_offset=8

# Default styling - with pill backgrounds and hover
default=(
  padding_left=4
  padding_right=4
  icon.font="CaskaydiaCove Nerd Font:Bold:14.0"
  label.font="CaskaydiaCove Nerd Font:Bold:14.0"
  icon.color=0xffc4a7e7
  label.color=0xffe0def4
  icon.padding_left=8
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=8
  background.color=0x660c0c0c
  background.corner_radius=8
  background.height=26
  background.drawing=on
  popup.background.color=0xe60c0c0c
  popup.background.corner_radius=8
  popup.background.drawing=on
  popup.blur_radius=20
  
)
sketchybar --default "${default[@]}"

sketchybar --set default popup.background.height=0

# Rosepine theme colors
# Background: 090B10, Surface: 1f1d2e, Text: e0def4
# Subtle: 6e6a86, Muted: 908caa
# Accent: c4a7e7 (lavender), Love: eb6f92 (pink), Gold: f6c177
COLOR_BG="0x700909B10"          # Semi-transparent dark
COLOR_INACTIVE="0x660c0c0c"     # Ghostty dark transparent
COLOR_TEXT_MUTED=0xff908caa     # Muted text
COLOR_TEXT=0xffe0def4           # Active text
COLOR_ACCENT=0xffc4a7e7         # Lavender
COLOR_LOVE=0xffeb6f92           # Pink
COLOR_GOLD=0xfff6c177           # Gold
COLOR_SURFACE=0xff1f1d2e        # Surface

sketchybar --add event mouse.entered
sketchybar --add event mouse.exited
sketchybar --add event mouse.clicked
sketchybar --add event omniwm_workspace_change

# Create workspace items with Hyperland-style appearance
omniwmctl query workspaces --format json | jq -r '.result.payload.workspaces[] | @json' | while read -r workspace; do
    sid=$(echo "$workspace" | jq -r '.id')
    label=$(echo "$workspace" | jq -r '.displayName' | sed 's/^ *//')
    [ -z "$sid" ] && continue

    # Assign colors based on workspace number
    case "$label" in
        1) ACCENT=$COLOR_ACCENT_CYAN ;;
        2) ACCENT=$COLOR_ACCENT_PINK ;;
        3) ACCENT=$COLOR_ACCENT_GREEN ;;
        4) ACCENT=$COLOR_ACCENT_YELLOW ;;
        5) ACCENT=$COLOR_ACCENT_PEACH ;;
        6) ACCENT=$COLOR_ACCENT_MAUVE ;;
        7) ACCENT=$COLOR_ACCENT_CYAN ;;
        8) ACCENT=$COLOR_ACCENT_PINK ;;
        *) ACCENT=$COLOR_ACCENT_GREEN ;;
    esac

    sketchybar --add item space.$sid left \
        --subscribe space.$sid omniwm_workspace_change \
        --set space.$sid \
        icon="$label" \
        icon.color=$COLOR_TEXT_MUTED \
        icon.font="CaskaydiaCove Nerd Font:Bold:14.0" \
        icon.padding_left=8 \
        icon.padding_right=8 \
        label.drawing=off \
        background.color=$COLOR_INACTIVE \
        background.drawing=on \
        background.corner_radius=8 \
        click_script="omniwmctl workspace focus-name $sid" \
        script="$CONFIG_DIR/plugins/omniwm.sh"
done

# Spacer to separate left and right groups
sketchybar --add item spacer center \
    --set spacer \
    background.drawing=off \
    width=80

# Right side items - Rosepine icons
sketchybar --add item clock right \
    --set clock \
    update_freq=10 \
    icon="󰥔" \
    icon.color=$COLOR_GOLD \
    icon.font="CaskaydiaCove Nerd Font:Bold:14.0" \
    script="$PLUGIN_DIR/clock.sh" \
    click_script="open /System/Library/PreferencePanes/DateAndTime.prefPane" \
    --subscribe clock mouse.entered mouse.exited

# Only add battery if a battery exists
if pmset -g batt 2>/dev/null | grep -q "%"; then
sketchybar --add item battery right \
      --set battery \
      update_freq=120 \
      icon="󰁺" \
