PLUGIN_DIR="$CONFIG_DIR/plugins"

##### Bar Appearance #####
# Configuring the general appearance of the bar with Rosepine theme.
# Background: 090B10, Surface: 1f1d2e, Text: e0def4

sketchybar --bar position=top height=28 blur_radius=30 color=0x40000000 sticky=on margin=0 padding_left=4 padding_right=4

##### Changing Defaults #####
# Rosepine theme colors: Text: e0def4, Subtle: 6e6a86, Muted: 908caa
# Accent: c4a7e7 (lavender), Love: eb6f92 (pink), Gold: f6c177
default=(
  padding_left=4
  padding_right=4
  icon.font="CaskaydiaCove Nerd Font:Medium:15.0"
  label.font="CaskaydiaCove Nerd Font:Regular:13.0"
  icon.color=0xffe0def4
  label.color=0xffe0def4
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
)
sketchybar --default "${default[@]}"

sketchybar --add event omniwm_workspace_change

omniwmctl query workspaces --format json | jq -r '.result.payload.workspaces[] | @json' | while read -r workspace; do
    sid=$(echo "$workspace" | jq -r '.id')
    label=$(echo "$workspace" | jq -r '.displayName')
    [ -z "$sid" ] && continue
    sketchybar --add item space.$sid left \
        --subscribe space.$sid omniwm_workspace_change \
        --set space.$sid \
        background.color=0xff090b10 \
        background.corner_radius=4 \
        background.height=20 \
        background.drawing=off \
        label="$label" \
        label.font="CaskaydiaCove Nerd Font:Medium:12.0" \
        label.color=0xff908caa \
        padding_left=8 \
        padding_right=8 \
        click_script="omniwmctl workspace focus-name $sid" \
        script="$CONFIG_DIR/plugins/omniwm.sh $sid"
done

sketchybar --add item clock right \
           --set clock update_freq=10 script="$PLUGIN_DIR/clock.sh" \
           --add item battery right \
           --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change \
           --add item claude_usage right \
           --set claude_usage update_freq=60 \
           icon="✳" \
           icon.color=0xffda7756 \
           label.font="CaskaydiaCove Nerd Font:Regular:12.0" \
           script="$PLUGIN_DIR/claude_usage.sh" \

# Start the OmniWM workspace watcher (background daemon for instant updates)
launchctl load $HOME/Library/LaunchAgents/com.omniwm.sketchybar-watcher.plist 2>/dev/null

sketchybar --update
