#!/usr/bin/env bash

set -euo pipefail

for path_entry in "$HOME/.local/bin" "/opt/homebrew/bin" "/usr/local/bin"; do
	case ":$PATH:" in
		*":$path_entry:"*) ;;
		*) PATH="$PATH:$path_entry" ;;
	esac
done
export PATH
unset path_entry

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/kitty-sessionizer"
SESSION_DIR="$CACHE_DIR/sessions"

hold_on_error() {
	local status=$?

	trap - EXIT

	if [[ $status -ne 0 && -n "${KITTY_SESSIONIZER_HOLD:-}" ]]; then
		echo
		echo "kitty-worktree exited with status $status"
		printf "Press enter to close..."
		read -r _ </dev/tty || true
	fi

	exit "$status"
}

trap hold_on_error EXIT

require_cmd() {
	local cmd="$1"
	local hint="$2"

	if ! command -v "$cmd" >/dev/null 2>&1; then
		echo "$cmd is not installed or not in PATH." >&2
		echo "$hint" >&2
		exit 1
	fi
}

pretty_path() {
	local path="$1"

	if [[ "$path" == "$HOME" ]]; then
		printf "~"
	elif [[ "$path" == "$HOME/"* ]]; then
		printf "~/%s" "${path#"$HOME"/}"
	else
		printf "%s" "$path"
	fi
}

sanitize_name() {
	local name="$1"

	name="$(printf "%s" "$name" | tr -cs "A-Za-z0-9._-" "_" | sed "s/^_//;s/_$//")"
	if [[ -z "$name" ]]; then
		name="workspace"
	fi

	printf "%s" "$name"
}

hash_path() {
	printf "%s" "$1" | shasum -a 256 | awk '{print substr($1, 1, 8)}'
}

quote_session_arg() {
	printf "'%s'" "$(printf "%s" "$1" | sed "s/'/'\\\\''/g")"
}

repo_root() {
	local git_common_dir
	git_common_dir="$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"

	if [[ "$git_common_dir" == */.git ]]; then
		printf "%s" "${git_common_dir%/.git}"
	else
		git rev-parse --show-toplevel
	fi
}

open_as_session() {
	local path="$1"
	local base safe_base session_file hash

	base="$(basename "$path")"
	safe_base="$(sanitize_name "$base")"

	mkdir -p "$SESSION_DIR"

	session_file="$SESSION_DIR/$safe_base.kitty-session"

	if [[ -f "$session_file" ]] && ! grep -Fxq "# kitty-sessionizer-path: $path" "$session_file"; then
		hash="$(hash_path "$path")"
		session_file="$SESSION_DIR/$safe_base-$hash.kitty-session"
	fi

	cat >"$session_file" <<EOF
# Generated by kitty-worktree. Edits may be overwritten.
# kitty-sessionizer-path: $path
layout tall
cd $path
launch --title $(quote_session_arg "$base")
focus
focus_os_window
EOF

	kitten @ action goto_session "$session_file"
}

build_menu() {
	local root="$1"
	local path="" branch="" head="" bare=""

	while IFS= read -r line; do
		if [[ -z "$line" ]]; then
			if [[ -n "$path" ]]; then
				local label
				if [[ "$path" == "$root" ]]; then
					label="(main worktree)"
				else
					label=""
				fi
				printf "worktree\t%s\t%s\t%-20s %s %s\n" \
					"$path" "$branch" "[$branch]" "$(pretty_path "$path")" "$label"
			fi
			path="" branch="" head="" bare=""
			continue
		fi

		case "$line" in
			"worktree "*)  path="${line#worktree }" ;;
			"branch "*)    branch="${line#branch refs/heads/}" ;;
			"HEAD "*)      head="${line#HEAD }" ;;
			"detached")    branch="(detached)" ;;
			"bare")        bare="true" ;;
		esac
	done < <(git -C "$root" worktree list --porcelain; echo)

	printf "create\t\t\t+ Create new worktree\n"
}

available_branches() {
	local root="$1"
	local worktree_branches

	worktree_branches="$(git -C "$root" worktree list --porcelain | grep '^branch ' | sed 's|^branch refs/heads/||')"

	{
		git -C "$root" for-each-ref --format='%(refname:short)' refs/heads/
		git -C "$root" for-each-ref --format='%(refname:short)' refs/remotes/ | sed 's|^[^/]*/||'
	} | sort -u | grep -v '^HEAD$' | while IFS= read -r branch; do
		if ! printf "%s\n" "$worktree_branches" | grep -Fxq "$branch"; then
			printf "%s\n" "$branch"
		fi
	done
}

create_worktree() {
	local root="$1"
	local worktree_dir="$root/.worktrees"
	local branch_name dir_name worktree_path

	branch_name="$(
		{
			printf "+ New branch\n"
			available_branches "$root" || true
		} | fzf --ansi --height=100% --reverse \
			--prompt="Branch > " \
			--header="Pick a branch or create new" \
			--no-multi
	)" || return 1

	[[ -n "$branch_name" ]] || return 1

	local is_new_branch=false
	if [[ "$branch_name" == "+ New branch" ]]; then
		printf "New branch name: " >/dev/tty
		read -r branch_name </dev/tty || return 1
		[[ -n "$branch_name" ]] || return 1
		branch_name="${branch_name// /-}"
		is_new_branch=true
	fi

	dir_name="${branch_name//\//-}"
	worktree_path="$worktree_dir/$dir_name"

	mkdir -p "$worktree_dir"

	if [[ "$is_new_branch" == true ]]; then
		git -C "$root" worktree add -b "$branch_name" "$worktree_path" >&2 || return 1
	else
		git -C "$root" worktree add "$worktree_path" "$branch_name" >&2 || return 1
	fi

	if [[ ! -d "$worktree_path" ]]; then
		echo "Worktree directory was not created at $worktree_path" >&2
		return 1
	fi

	printf "%s" "$worktree_path"
}

select_worktree() {
	local root
	root="$(repo_root)"

	local selected
	selected="$(
		build_menu "$root" |
			fzf --ansi --height=100% --reverse \
				--prompt="Worktree > " \
				--header="Enter: switch/create, Esc: cancel" \
				--delimiter=$'\t' \
				--with-nth=4.. \
				--no-multi
	)" || exit 0

	[[ -n "$selected" ]] || exit 0

	local kind target
	IFS=$'\t' read -r kind target _ _ <<<"$selected"

	case "$kind" in
		worktree)
			open_as_session "$target"
			;;
		create)
			local new_path
			new_path="$(create_worktree "$root")" || exit 1
			open_as_session "$new_path"
			;;
		*)
			echo "Unknown selection: $kind" >&2
			exit 1
			;;
	esac
}

main() {
	case "${1:-}" in
		-h | --help)
			cat <<EOF
Usage: kitty-worktree

Open an fzf worktree switcher for the current git repo.
Lists existing worktrees and offers to create new ones.
Each worktree opens as a Kitty session.
EOF
			exit 0
			;;
		*)
			require_cmd git "Install git."
			require_cmd fzf "Install with: brew install fzf"
			require_cmd kitten "Install Kitty or make sure kitten is on PATH."

			if ! git rev-parse --git-dir >/dev/null 2>&1; then
				echo "Not inside a git repository." >&2
				exit 1
			fi

			select_worktree
			;;
	esac
}

main "$@"
