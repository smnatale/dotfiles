#!/usr/bin/env bash

set -euo pipefail

for path_entry in "$HOME/.local/bin" "/opt/homebrew/bin" "/usr/local/bin"; do
	case ":$PATH:" in
		*":$path_entry:"*) ;;
		*) PATH="$PATH:$path_entry" ;;
	esac
done
export PATH
unset path_entry

hold_on_error() {
	local status=$?

	trap - EXIT

	if [[ $status -ne 0 && -n "${KITTY_SESSIONIZER_HOLD:-}" ]]; then
		echo
		echo "kitty-sessionizer exited with status $status"
		printf "Press enter to close..."
		read -r _ </dev/tty || true
	fi

	exit "$status"
}

trap hold_on_error EXIT

CONFIG_FILE_NAME="kitty-sessionizer.conf"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/kitty-sessionizer"
CONFIG_FILE="$CONFIG_DIR/$CONFIG_FILE_NAME"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/kitty-sessionizer"
SESSION_DIR="$CACHE_DIR/sessions"

if [[ -f "$CONFIG_FILE" ]]; then
	source "$CONFIG_FILE"
fi

if [[ -f "$CONFIG_FILE_NAME" ]]; then
	source "$CONFIG_FILE_NAME"
fi

[[ -n "${KS_SEARCH_PATHS+x}" ]] || KS_SEARCH_PATHS=("$HOME/Projects/work" "$HOME/dotfiles" "$HOME/Projects/personal")

if declare -p KS_EXTRA_SEARCH_PATHS >/dev/null 2>&1 && [[ ${#KS_EXTRA_SEARCH_PATHS[@]} -gt 0 ]]; then
	KS_SEARCH_PATHS+=("${KS_EXTRA_SEARCH_PATHS[@]}")
fi

usage() {
	cat <<EOF
Usage: kitty-sessionizer [PROJECT_PATH]

Open an fzf workspace switcher for Kitty sessions and project directories.

Config: $CONFIG_FILE
  KS_SEARCH_PATHS=(~/Projects/work ~/dotfiles ~/Projects/personal:2)
  KS_EXTRA_SEARCH_PATHS=(~/src:2)
EOF
}

require_cmd() {
	local cmd="$1"
	local hint="$2"

	if ! command -v "$cmd" >/dev/null 2>&1; then
		echo "$cmd is not installed or not in PATH." >&2
		echo "$hint" >&2
		exit 1
	fi
}

expand_path() {
	local path="$1"

	case "$path" in
		"~")
			printf "%s\n" "$HOME"
			;;
		~/*)
			printf "%s\n" "$HOME/${path#~/}"
			;;
		*)
			printf "%s\n" "$path"
			;;
	esac
}

normalize_dir() {
	local path

	path="$(expand_path "$1")"
	if [[ ! -d "$path" ]]; then
		return 1
	fi

	(
		cd "$path"
		pwd -P
	)
}

pretty_path() {
	local path="$1"

	if [[ "$path" == "$HOME" ]]; then
		printf "~"
	elif [[ "$path" == "$HOME/"* ]]; then
		printf "~/%s" "${path#"$HOME"/}"
	else
		printf "%s" "$path"
	fi
}

sanitize_name() {
	local name="$1"

	name="$(printf "%s" "$name" | tr -cs "A-Za-z0-9._-" "_" | sed "s/^_//;s/_$//")"
	if [[ -z "$name" ]]; then
		name="workspace"
	fi

	printf "%s" "$name"
}

hash_path() {
	printf "%s" "$1" | shasum -a 256 | awk '{print substr($1, 1, 8)}'
}

quote_session_arg() {
	printf "'%s'" "$(printf "%s" "$1" | sed "s/'/'\\\\''/g")"
}

session_file_for_path() {
	local path="$1"
	local base="$2"
	local safe_base
	local file
	local hash

	mkdir -p "$SESSION_DIR"

	safe_base="$(sanitize_name "$base")"
	file="$SESSION_DIR/$safe_base.kitty-session"

	if [[ -f "$file" ]] && ! grep -Fxq "# kitty-sessionizer-path: $path" "$file"; then
		hash="$(hash_path "$path")"
		file="$SESSION_DIR/$safe_base-$hash.kitty-session"
	fi

	printf "%s" "$file"
}

write_session_file() {
	local path="$1"
	local file="$2"
	local title="$3"

	cat >"$file" <<EOF
# Generated by kitty-sessionizer. Edits may be overwritten.
# kitty-sessionizer-path: $path
layout tall
cd $path
launch --title $(quote_session_arg "$title")
focus
focus_os_window
EOF
}

kitty_ls() {
	if ! kitten @ ls 2>/dev/null; then
		cat >&2 <<EOF
kitty-sessionizer needs Kitty remote control.

Run it inside Kitty with allow_remote_control enabled, or via:
  map f12>f launch --type=overlay --allow-remote-control /bin/zsh -lc 'KITTY_SESSIONIZER_HOLD=1 kitty-sessionizer'
EOF
		exit 1
	fi
}

open_session_lines() {
	local data="$1"

	printf "%s" "$data" | jq -r '
		[
			.[] as $os
			| $os.tabs[]? as $tab
			| $tab.windows[]?
			| select(.session_name != null and .session_name != "")
			| {
				name: .session_name,
				cwd: (.env.PWD // .cwd // ""),
				last: (.last_focused_at // 0),
				focused: (if (($os.is_focused // false) and ($tab.is_focused // false)) then 1 else 0 end)
			}
		]
		| sort_by(.name)
		| group_by(.name)
		| map(sort_by(-.focused, -.last) | .[0])
		| sort_by(-.last, .name)
		| .[]
		| ["session", .name, (.cwd | tostring), ("[open] " + .name + "  " + (.cwd | tostring))]
		| @tsv
	'
}

open_session_paths() {
	local data="$1"

	printf "%s" "$data" | jq -r '
		.[]?.tabs[]?.windows[]?
		| select(.session_name != null and .session_name != "")
		| (.env.PWD // .cwd // empty)
	'
}

find_project_dirs() {
	local entry
	local path
	local depth

	for entry in "${KS_SEARCH_PATHS[@]}"; do
		depth="${KS_MAX_DEPTH:-1}"
		if [[ "$entry" =~ ^(.+):([0-9]+)$ ]]; then
			path="${BASH_REMATCH[1]}"
			depth="${BASH_REMATCH[2]}"
		else
			path="$entry"
		fi

		path="$(expand_path "$path")"
		[[ -d "$path" ]] || continue

		find "$path" -mindepth 1 -maxdepth "$depth" -path "*/.git" -prune -o -type d -print |
			sort
	done
}

is_known_open_path() {
	local path="$1"
	local open_paths_file="$2"

	grep -Fxq "$path" "$open_paths_file"
}

build_menu() {
	local kitty_data="$1"
	local open_paths_file="$2"
	local project
	local real
	local base
	local pretty
	local seen_projects_file

	open_session_lines "$kitty_data"
	seen_projects_file="$(mktemp "${TMPDIR:-/tmp}/kitty-sessionizer-seen-projects.XXXXXX")"
	trap "rm -f '$open_paths_file' '$seen_projects_file'" EXIT

	while IFS= read -r project; do
		real="$(normalize_dir "$project" || true)"
		[[ -n "$real" ]] || continue

		if is_known_open_path "$real" "$open_paths_file"; then
			continue
		fi

		if grep -Fxq "$real" "$seen_projects_file"; then
			continue
		fi
		printf "%s\n" "$real" >>"$seen_projects_file"

		base="$(basename "$real")"
		pretty="$(pretty_path "$real")"
		printf "project\t%s\t%s\t[new]  %s  %s\n" "$real" "$real" "$base" "$pretty"
	done < <(find_project_dirs)
}

focus_or_launch_project() {
	local path
	local base
	local session_file

	path="$(normalize_dir "$1")"
	base="$(basename "$path")"
	session_file="$(session_file_for_path "$path" "$base")"
	write_session_file "$path" "$session_file" "$base"
	kitten @ action goto_session "$session_file"
}

select_workspace() {
	local kitty_data
	local open_paths_file
	local selected
	local kind
	local target
	local path
	local display

	kitty_data="$(kitty_ls)"
	open_paths_file="$(mktemp "${TMPDIR:-/tmp}/kitty-sessionizer-open-paths.XXXXXX")"
	trap "rm -f '$open_paths_file'" EXIT

	while IFS= read -r path; do
		normalize_dir "$path" 2>/dev/null || true
	done < <(open_session_paths "$kitty_data") | sort -u >"$open_paths_file"

	selected="$(
		build_menu "$kitty_data" "$open_paths_file" |
			fzf --ansi --height=100% --reverse \
				--prompt="Kitty Workspace > " \
				--header="Enter: switch/create, Esc: cancel" \
				--delimiter=$'\t' \
				--with-nth=4.. \
				--no-multi
	)" || exit 0

	[[ -n "$selected" ]] || exit 0

	IFS=$'\t' read -r kind target path display <<<"$selected"

	case "$kind" in
		session)
			kitten @ action goto_session "$target"
			;;
		project)
			focus_or_launch_project "$target"
			;;
		*)
			echo "Unknown workspace type: $kind" >&2
			exit 1
			;;
	esac
}

main() {
	case "${1:-}" in
		-h | --help)
			usage
			exit 0
			;;
		"")
			require_cmd kitten "Install Kitty or make sure kitten is on PATH."
			require_cmd fzf "Install with: brew install fzf"
			require_cmd jq "Install with: brew install jq"
			select_workspace
			;;
		*)
			require_cmd kitten "Install Kitty or make sure kitten is on PATH."
			kitty_ls >/dev/null
			focus_or_launch_project "$1"
			;;
	esac
}

main "$@"
